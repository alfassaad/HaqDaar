rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Allow reading profiles for authenticated users
      allow read: if isAuthenticated();

      // Allow writing if the user is updating their own profile or is an admin
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());

      match /transactions/{txId} {
        // Allow reading/writing transactions for the profile owner or an admin
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }
    
    // Fallback for other collections if any
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}